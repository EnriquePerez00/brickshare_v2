# Brickshare Environment Variables Template
# Copy this file to .env and fill in actual values

# ═══════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Local development (obtained from `supabase status`)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Edge Functions
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════════
# PAYMENT SERVICE (Stripe)
# ═══════════════════════════════════════════════════════════════

# Test mode keys from Stripe dashboard
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ═══════════════════════════════════════════════════════════════
# EMAIL SERVICE (Resend)
# ═══════════════════════════════════════════════════════════════
# See docs/RESEND_CONFIGURATION.md and docs/RESEND_SANDBOX_SETUP.md

RESEND_API_KEY=a7937760-ab2b-47a1-9a95-746c7fa7ad63
RESEND_FROM_DOMAIN=brickclinic.eu
RESEND_FROM_EMAIL=info@brickclinic.eu
RESEND_SANDBOX_RECIPIENT=enriqueperezbcn1973@gmail.com
RESEND_DEVELOP_EMAIL=info@brickclinic.eu

# ═══════════════════════════════════════════════════════════════
# LOGISTICS & DELIVERY (Correos)
# ═══════════════════════════════════════════════════════════════

CORREOS_API_USER=your_correos_user
CORREOS_API_PASSWORD=your_correos_password
CORREOS_SENDER_CODE=your_sender_code

# ═══════════════════════════════════════════════════════════════
# GUARANTEES (Swikly)
# ═══════════════════════════════════════════════════════════════

# Swikly Test Credentials
SWIKLY_API_KEY=test_api_key_here
SWIKLY_MERCHANT_ID=merchant_id_here
SWIKLY_ACCOUNT_ID=account_id_here

# Development bypass (set to 'true' to skip Swikly in dev)
VITE_SKIP_SWIKLY_IN_DEV=false

# ═══════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════

VITE_APP_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT & ENVIRONMENT
# ═══════════════════════════════════════════════════════════════

# Set to 'true' for production deployments
PROD=false