# Supabase Local Configuration
# Obtener estas credenciales ejecutando: supabase status

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe Configuration (Test Keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Swikly V2 Configuration (Depósitos de garantía)
# Sandbox: https://api.v2.sandbox.swikly.com/v1
# Producción: https://api.v2.swikly.com/v1
SWIKLY_API_TOKEN=your_swikly_bearer_token_here
SWIKLY_ACCOUNT_ID=your_swikly_account_uuid_here
SWIKLY_WEBHOOK_SECRET=your_swikly_webhook_signing_secret_here

# Correos API Configuration (Optional)
CORREOS_API_KEY=your_correos_key_here
CORREOS_API_URL=https://api.correos.es

# Email Configuration (Optional - for Resend)
RESEND_API_KEY=re_your_key_here

# Lego APIs (Optional)
BRICKSET_API_KEY=your_brickset_key_here
REBRICKABLE_API_KEY=your_rebrickable_key_here