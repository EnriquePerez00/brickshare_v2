{
  "name": "brickshare",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo Brickshare: aplicación web con backend Supabase",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @brickshare/web",
    "dev:web": "npm run dev -w @brickshare/web",
    "build": "npm run build -w @brickshare/web",
    "build:web": "npm run build -w @brickshare/web",
    "build:shared": "npm run build -w @brickshare/shared",
    "lint": "npm run lint -w @brickshare/web",
    "lint:web": "npm run lint -w @brickshare/web",
    "test": "npm run test -w @brickshare/web",
    "test:watch": "npm run test:watch -w @brickshare/web",
    "dump-schema": "bash scripts/update-schema-docs.sh",
    "supabase:start": "bash scripts/supabase-environments.sh start",
    "supabase:stop": "bash scripts/supabase-environments.sh stop",
    "supabase:status": "bash scripts/supabase-environments.sh status",
    "supabase:reset": "bash scripts/supabase-environments.sh reset",
    "supabase:dump": "bash scripts/supabase-environments.sh dump",
    "supabase:help": "bash scripts/supabase-environments.sh help"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0"
  }
}
